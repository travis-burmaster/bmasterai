# API Keys
GOOGLE_API_KEY=your_google_api_key_here

TAVILY_API_KEY=your_tavily_api_key_here
THE_ODDS_API_KEY=your_odds_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# OpenAI Configuration (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/sports_betting
REDIS_URL=redis://localhost:6379/0

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# Logging Configuration
LOG_LEVEL=INFO
BMASTERAI_LOG_FILE=sports_betting_analysis.log
BMASTERAI_JSON_LOG_FILE=sports_betting_analysis.json

